# Zeabur: paste these in each service's "Variables" tab.
# Replace YOUR_* placeholders with Zeabur domains and generated secrets.

# ========== BACKEND (office_suite/docs, Dockerfile target: backend-production) ==========
DJANGO_CONFIGURATION=Production
DJANGO_ALLOWED_HOSTS=YOUR_BACKEND_DOMAIN,localhost
DJANGO_SECRET_KEY=YOUR_LONG_RANDOM_SECRET
SECURE_SSL_REDIRECT=True
CORS_ALLOW_ALL_ORIGINS=False

DATABASE_URL=YOUR_ZEABUR_POSTGRES_CONNECTION_STRING
REDIS_URL=YOUR_ZEABUR_REDIS_CONNECTION_STRING

IMPRESS_BASE_URL=https://YOUR_FRONTEND_DOMAIN
MEDIA_BASE_URL=https://YOUR_BACKEND_DOMAIN/media

# S3: Zeabur object storage OR self-hosted MinIO URL
AWS_S3_ENDPOINT_URL=https://YOUR_S3_ENDPOINT
AWS_S3_ACCESS_KEY_ID=YOUR_S3_KEY
AWS_S3_SECRET_ACCESS_KEY=YOUR_S3_SECRET
AWS_STORAGE_BUCKET_NAME=grow24-office-docs-media-storage
AWS_S3_USE_SSL=True
STORAGES_DEFAULT_BACKEND=impress.core.storages.MediaStorage

# Keycloak (public HTTPS URLs — same host for browser + server on Zeabur)
OIDC_OP_AUTHORIZATION_ENDPOINT=https://YOUR_KEYCLOAK_DOMAIN/realms/grow24/protocol/openid-connect/auth
OIDC_OP_JWKS_ENDPOINT=https://YOUR_KEYCLOAK_DOMAIN/realms/grow24/protocol/openid-connect/certs
OIDC_OP_TOKEN_ENDPOINT=https://YOUR_KEYCLOAK_DOMAIN/realms/grow24/protocol/openid-connect/token
OIDC_OP_USER_ENDPOINT=https://YOUR_KEYCLOAK_DOMAIN/realms/grow24/protocol/openid-connect/userinfo
OIDC_OP_LOGOUT_ENDPOINT=https://YOUR_KEYCLOAK_DOMAIN/realms/grow24/protocol/openid-connect/logout
OIDC_RP_CLIENT_ID=office_docs
OIDC_RP_CLIENT_SECRET=YOUR_KEYCLOAK_CLIENT_SECRET

LOGIN_REDIRECT_URL=https://YOUR_FRONTEND_DOMAIN
LOGIN_REDIRECT_URL_FAILURE=https://YOUR_FRONTEND_DOMAIN/login-error
LOGOUT_REDIRECT_URL=https://YOUR_FRONTEND_DOMAIN
OIDC_REDIRECT_ALLOWED_HOSTS=["https://YOUR_BACKEND_DOMAIN","https://YOUR_FRONTEND_DOMAIN","https://YOUR_KEYCLOAK_DOMAIN"]

COLLABORATION_API_URL=https://YOUR_YPROVIDER_DOMAIN/collaboration/api/
COLLABORATION_BACKEND_BASE_URL=https://YOUR_BACKEND_DOMAIN/
COLLABORATION_SERVER_ORIGIN=https://YOUR_FRONTEND_DOMAIN
COLLABORATION_SERVER_SECRET=YOUR_COLLAB_SECRET
COLLABORATION_WS_URL=wss://YOUR_YPROVIDER_DOMAIN/collaboration/ws/

Y_PROVIDER_API_BASE_URL=https://YOUR_YPROVIDER_DOMAIN/api/
Y_PROVIDER_API_KEY=YOUR_Y_PROVIDER_KEY
Y_PROVIDER_BACKEND_URL=https://YOUR_BACKEND_DOMAIN

SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ========== FRONTEND (build arg at deploy time) ==========
# API_ORIGIN=https://YOUR_BACKEND_DOMAIN

# ========== Y-PROVIDER ==========
# Same COLLABORATION_* and Y_PROVIDER_* as backend, plus env_file overlap
