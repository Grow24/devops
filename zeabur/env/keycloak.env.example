# Zeabur service: keycloak (Docker image quay.io/keycloak/keycloak:24.0)
# Settings → CMD (Arguments): start --hostname-strict=false --http-enabled=true
# Settings → Dockerfile override: EMPTY
# Networking → public port 8080 → keycloak.zeabur.app

KC_DB=postgres
KC_DB_URL_HOST=service-6a09230b1985c8ed80e28e7e.zeabur.internal
KC_DB_URL_PORT=5432
KC_DB_URL_DATABASE=keycloak_db
KC_DB_USERNAME=root
KC_DB_PASSWORD=YOUR_PG_PASSWORD_SAME_AS_POSTGRES_CONNECT

KC_HOSTNAME=keycloak.zeabur.app
KC_HOSTNAME_STRICT=false
KC_HTTP_ENABLED=true
KC_PROXY=edge

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD

PORT=8080
