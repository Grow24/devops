# Zeabur service: docs-frontend
# ONLY these — remove DJANGO_*, DATABASE_URL, OIDC_*, PASSWORD, *_HOST from Variable tab

ZBPACK_DOCKERFILE_PATH=src/frontend/Dockerfile

# Build arguments (required at build time)
API_ORIGIN=https://devopsdev.zeabur.app
DOCKER_USER=1000
PUBLISH_AS_MIT=false
SW_DEACTIVATED=true

# Runtime (Zeabur injects PORT; nginx listens on 8080 in image)
PORT=8080
