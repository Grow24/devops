# Zeabur service: devops (Django backend)
# Copy ALL lines to devops → Variable → Edit Raw (replace YOUR_* and paste Connect URLs)

PORT=8080
PYTHONUNBUFFERED=1
DJANGO_CONFIGURATION=Production

# --- Hosts ---
DJANGO_ALLOWED_HOSTS=devopsdev.zeabur.app
ALLOWED_HOSTS=devopsdev.zeabur.app

# --- Secrets (generate your own; do not commit real values) ---
DJANGO_SECRET_KEY=YOUR_50_PLUS_CHAR_RANDOM_SECRET

# --- Zeabur PostgreSQL → Connect tab (internal URL) ---
# Database name must exist: office_suite_docs_db (see zeabur/postgres/create-databases.sql)
DATABASE_URL=postgres://root:YOUR_PG_PASSWORD@service-6a09230b1985c8ed80e28e7e.zeabur.internal:5432/office_suite_docs_db

# --- Zeabur Redis → Connect tab (required — without REDIS_URL every request = 500) ---
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@service-6a09231d1985c8ed80e28e8d.zeabur.internal:6379/0

# --- HTTPS / cookies (behind Zeabur proxy) ---
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=["https://devopsdocs.zeabur.app"]
CSRF_TRUSTED_ORIGINS=["https://devopsdocs.zeabur.app"]

# --- Public URLs ---
IMPRESS_BASE_URL=https://devopsdocs.zeabur.app
MEDIA_BASE_URL=https://devopsdev.zeabur.app/media
LOGIN_REDIRECT_URL=https://devopsdocs.zeabur.app
LOGIN_REDIRECT_URL_FAILURE=https://devopsdocs.zeabur.app/login-error
LOGOUT_REDIRECT_URL=https://devopsdocs.zeabur.app

# --- Keycloak OIDC (public HTTPS — same host for all four) ---
OIDC_OP_AUTHORIZATION_ENDPOINT=https://keycloak.zeabur.app/realms/grow24/protocol/openid-connect/auth
OIDC_OP_JWKS_ENDPOINT=https://keycloak.zeabur.app/realms/grow24/protocol/openid-connect/certs
OIDC_OP_TOKEN_ENDPOINT=https://keycloak.zeabur.app/realms/grow24/protocol/openid-connect/token
OIDC_OP_USER_ENDPOINT=https://keycloak.zeabur.app/realms/grow24/protocol/openid-connect/userinfo
OIDC_OP_LOGOUT_ENDPOINT=https://keycloak.zeabur.app/realms/grow24/protocol/openid-connect/logout
OIDC_RP_CLIENT_ID=office_docs
OIDC_RP_CLIENT_SECRET=YOUR_OFFICE_DOCS_CLIENT_SECRET_FROM_KEYCLOAK
OIDC_RP_SIGN_ALGO=RS256
OIDC_RP_SCOPES=openid email profile
OIDC_REDIRECT_ALLOWED_HOSTS=["https://devopsdev.zeabur.app","https://devopsdocs.zeabur.app","https://keycloak.zeabur.app"]

# --- S3 / MinIO (after MinIO service is deployed) ---
STORAGES_DEFAULT_BACKEND=impress.core.storages.MediaStorage
AWS_S3_ENDPOINT_URL=https://YOUR_MINIO_DOMAIN
AWS_S3_ACCESS_KEY_ID=admin
AWS_S3_SECRET_ACCESS_KEY=Admin@12345
AWS_STORAGE_BUCKET_NAME=grow24-office-docs-media-storage
AWS_S3_USE_SSL=True

# --- Collaboration (after y-provider is deployed) ---
COLLABORATION_API_URL=https://YOUR_YPROVIDER_DOMAIN/collaboration/api/
COLLABORATION_BACKEND_BASE_URL=https://devopsdev.zeabur.app/
COLLABORATION_SERVER_ORIGIN=https://devopsdocs.zeabur.app
COLLABORATION_SERVER_SECRET=YOUR_RANDOM_COLLAB_SECRET
COLLABORATION_WS_URL=wss://YOUR_YPROVIDER_DOMAIN/collaboration/ws/
Y_PROVIDER_API_BASE_URL=https://YOUR_YPROVIDER_DOMAIN/api/
Y_PROVIDER_API_KEY=YOUR_RANDOM_Y_PROVIDER_KEY
Y_PROVIDER_BACKEND_URL=https://devopsdev.zeabur.app
